// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum ParticipantStatus {
  IN_MEETING
  LEFT
}

enum UserRole {
  ADMIN
  MEMBER
}

// ── Dashboard login users (team) ──────────────────────────────────────────────
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String        @default("Admin")
  role         UserRole      @default(MEMBER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  authSessions AuthSession[]
}

// ── Dashboard refresh-token sessions (HttpOnly cookie auth) ─────────────────
model AuthSession {
  id          String   @id @default(cuid())
  userId      String
  refreshHash String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ── Parent meeting (one per Zoom meeting ID) ──────────────────────────────────
// Owns registrants. For recurring meetings, sessions are in MeetingSession.
model Meeting {
  id        String   @id           // Zoom parent meeting ID (as string)
  topic     String
  timezone  String?
  type      Int      @default(2)   // 2=one-time, 8=recurring
  joinUrl   String?
  hostId    String?                 // Zoom host_id from webhooks
  hostEmail String?                 // Zoom host email from webhooks
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrants Registrant[]
  sessions    MeetingSession[]
}

// ── One row per occurrence / session ─────────────────────────────────────────
// occurrenceId = Zoom's occurrence_id (scheduled start Unix ms, e.g. "1780659000000")
// uuid         = base64 UUID from meeting.started webhook (set when meeting actually starts)
// We link uuid → occurrenceId by finding the session whose scheduledStart is nearest
// to the actual start time reported in meeting.started.
model MeetingSession {
  id             String        @id @default(cuid())
  meetingId      String
  occurrenceId   String?       // Zoom occurrence_id — null for one-time meetings
  uuid           String?       // base64 UUID from meeting.started
  scheduledStart DateTime      // scheduled start time (from occurrence list)
  duration       Int           // minutes
  status         SessionStatus @default(SCHEDULED)
  endTime        DateTime?

  meeting      Meeting       @relation(fields: [meetingId], references: [id])
  participants Participant[]

  @@unique([meetingId, occurrenceId])
  @@index([uuid])
  @@index([meetingId, status])
}

// ── Registrant — one per user who registered for the meeting series ───────────
model Registrant {
  id        String   @id @default(cuid())
  zoomId    String
  meetingId String
  email     String
  name      String
  firstName String
  lastName  String
  sixABonus String   @default("")
  joinUrl   String?
  status    String   @default("approved")
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id])

  @@unique([meetingId, email])
}

// ── Participant — one row per person per session ──────────────────────────────
model Participant {
  id          String            @id @default(cuid())
  sessionId   String            // → MeetingSession
  email       String
  name        String
  userId      String?
  isHost      Boolean           @default(false)
  status      ParticipantStatus @default(IN_MEETING)
  joinTime    DateTime
  leaveTime   DateTime?
  duration    Int               @default(0)  // total ms across join sessions
  joinHistory Json              @default("[]")  // [{joinTime, leaveTime}]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  session MeetingSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, email])
}
