# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000

# ── Database (PostgreSQL on VPS) ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@localhost:5432/DATABASE
DATABASE_URL=postgresql://nsi_livemeet:CHANGE_ME@localhost:5432/nsi_livemeet

# ── Auth (generate strong random strings for production) ──────────────────────
JWT_SECRET=change-me-to-a-long-random-string
PASSWORD_SALT=change-me-to-another-long-random-string

# ── CORS (comma-separated frontend URLs) ──────────────────────────────────────
CORS_ORIGIN=https://your-frontend-domain.com

# ── Zoom Server-to-Server OAuth ───────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=
