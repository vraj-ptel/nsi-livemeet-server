# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000

# ── Database (PostgreSQL on VPS) ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@localhost:5432/DATABASE
DATABASE_URL=postgresql://nsi_livemeet:CHANGE_ME@localhost:5432/nsi_livemeet

# ── Auth (generate strong random strings for production) ──────────────────────
JWT_SECRET=change-me-to-a-long-random-string
PASSWORD_SALT=change-me-to-another-long-random-string

# ── HttpOnly cookies (cross-origin frontend + API) ────────────────────────────
# CORS_ORIGIN must match your frontend URL(s), comma-separated
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.com
# sameSite: none (cross-origin) | lax (same-site) | strict
COOKIE_SAME_SITE=none
# Secure cookies (true for production; localhost supports secure cookies in modern browsers)
COOKIE_SECURE=true
# Optional shared parent domain, e.g. .growithnsi.com when app and API are subdomains
# COOKIE_DOMAIN=.growithnsi.com
# Behind Nginx/reverse proxy in production
TRUST_PROXY=true

# ── Zoom Server-to-Server OAuth ───────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=
